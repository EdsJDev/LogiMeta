<ripple xmlns:android="http://schemas.android.com/apk/res/android"
    android:color="#65CA812C"> <!-- Efeito ripple ao clicar o botão laranja suave -->

    <item android:id="@android:id/mask">
        <shape android:shape="rectangle">
            <solid android:color="#946B4F" />
            <corners android:radius="25dp" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <!-- Fundo translúcido tipo vidro -->
            <solid android:color="#12C5A9A9" />

            <!-- Borda do botão -->
            <stroke
                android:color="#FED7B996"
                android:width="2dp" />

            <corners android:radius="25dp" /><!-- cor da borda do botão -->
        </shape>
    </item>
</ripple>
